-user-select: none;\n  font-family: var(--pp-font-family);\n}\n.panda-btn:disabled {\n  cursor: not-allowed;\n  opacity: 0.6;\n}\n.panda-btn:focus { outline: none; }\n.panda-btn:focus-visible {\n  outline: 2px solid var(--pp-foreground-40);\n  outline-offset: 1px;\n}\n.panda-btn--full {\n  width: 100%;\n}\n\n.panda-btn--primary {\n  background: var(--pp-primary);\n  color: var(--plyr-video-control-color, #fff);\n}\n.panda-btn--primary:hover:not(:disabled) {\n  background: var(--pp-primary-hover);\n}\n.panda-btn--primary:disabled {\n  color: var(--pp-primary-text-disable);\n}\n\n.panda-btn--secondary {\n  background: var(--pp-button-secondary-bg);\n  color: var(--pp-button-secondary-text);\n  border: 1px solid var(--pp-item-border-default);\n}\n.panda-btn--secondary:hover:not(:disabled) {\n  background: var(--pp-button-secondary-bg-hover);\n}\n\n.panda-btn--icon {\n  width: 32px;\n  height: 32px;\n  min-height: 32px;\n  padding: var(--pp-space-2);\n  border-radius: var(--pp-radius-icon);\n  background: transparent;\n  color: var(--pp-icon);\n}\n.panda-btn--icon:hover:not(:disabled) {\n  background: var(--pp-button-secondary-bg-hover);\n  color: var(--pp-icon-hover);\n}\n.panda-btn--icon svg {\n  width: 100%;\n  height: 100%;\n  display: block;\n}\n.panda-btn--icon-primary {\n  background: var(--pp-primary);\n  color: var(--plyr-video-control-color, #fff);\n}\n.panda-btn--icon-primary:hover:not(:disabled) {\n  background: var(--pp-primary-hover);\n}\n\n.panda-btn__icon {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n}\n.panda-btn__icon svg {\n  width: 16px;\n  height: 16px;\n  fill: currentColor;\n}\n\n.panda-input {\n  display: flex;\n  align-items: center;\n  gap: var(--pp-space-2);\n  background: var(--pp-input-bg);\n  border: 2px solid var(--pp-input-border);\n  border-radius: var(--pp-radius-pill);\n  padding: 6px var(--pp-space-2) 6px var(--pp-space-4);\n  min-height: 48px;\n  box-sizing: border-box;\n  transition: border-color var(--pp-transition);\n}\n.panda-input:focus-within {\n  border-color: var(--pp-input-border-focus);\n}\n.panda-input--disabled {\n  opacity: 0.6;\n  pointer-events: none;\n}\n.panda-input__field {\n  flex: 1;\n  background: transparent;\n  border: 0;\n  outline: 0;\n  color: var(--pp-input-text);\n  font: var(--pp-font-text);\n  min-width: 0;\n  padding: 0;\n  font-family: var(--pp-font-family);\n}\n.panda-input__field::placeholder {\n  color: var(--pp-input-placeholder);\n}\n\n.panda-card {\n  display: flex;\n  align-items: center;\n  gap: var(--pp-space-2);\n  padding: var(--pp-space-2) var(--pp-space-4);\n  min-height: 48px;\n  width: 100%;\n  background: transparent;\n  border: 1px solid var(--pp-item-border-default);\n  color: var(--pp-item-text);\n  font: var(--pp-font-button);\n  font-family: var(--pp-font-family);\n  text-align: left;\n  cursor: default;\n  box-sizing: border-box;\n  transition: background var(--pp-transition), border-color var(--pp-transition);\n}\nbutton.panda-card,\na.panda-card {\n  cursor: pointer;\n  font: var(--pp-font-button);\n  font-family: var(--pp-font-family);\n  color: var(--pp-item-text);\n}\nbutton.panda-card:hover:not(:disabled) {\n  background: var(--pp-item-bg-hover);\n}\n.panda-card--pill {\n  border-radius: var(--pp-radius-card);\n}\n.panda-card--rect {\n  border-radius: var(--pp-radius-rect);\n}\n.panda-card--active,\nbutton.panda-card--active,\na.panda-card--active {\n  border-width: 2px;\n  border-color: var(--pp-item-border-active);\n  background: var(--pp-item-bg-active);\n  color: var(--pp-foreground-100);\n  padding-block: calc(var(--pp-space-2) - 1px);\n  padding-inline: calc(var(--pp-space-4) - 1px);\n}\nbutton.panda-card--active:hover:not(:disabled) {\n  background: var(--pp-item-bg-active);\n}\n\n.panda-card--disabled,\nbutton.panda-card--disabled {\n  color: var(--pp-item-text-disable);\n  border-color: var(--pp-item-border-disable);\n  pointer-events: none;\n  cursor: default;\n}\nbutton.panda-card--disabled:hover {\n  background: transparent;\n  color: var(--pp-item-text-disable);\n}\n\n.panda-side-panel {\n  position: absolute;\n  top: 0;\n  right: 0;\n  bottom: 0;\n  width: min(584px, 100%);\n  display: flex;\n  flex-direction: column;\n  background: var(--pp-modal-bg);\n  border-left: 1px solid var(--pp-input-border);\n  border-radius: var(--pp-radius-panel) 0 0 var(--pp-radius-panel);\n  color: var(--pp-modal-title);\n  font-family: var(--pp-font-family);\n  z-index: var(--pp-z-side-panel);\n  overflow: hidden;\n  backdrop-filter: blur(var(--pp-blur));\n  -webkit-backdrop-filter: blur(var(--pp-blur));\n  transform: translateX(100%);\n  opacity: 0;\n  transition:\n    transform 0.42s cubic-bezier(0.32, 0.72, 0, 1),\n    opacity 0.32s ease-in-out;\n}\n.panda-side-panel--open {\n  transform: translateX(0);\n  opacity: 1;\n  transition:\n    transform 0.28s cubic-bezier(0.32, 0.72, 0, 1),\n    opacity 0.2s ease-out;\n}\n.panda-side-panel--closing {\n  transform: translateX(100%);\n  opacity: 0;\n  pointer-events: none;\n}\n\n.panda-side-panel__header {\n  display: flex;\n  align-items: center;\n  gap: var(--pp-space-2);\n  padding: var(--pp-space-4) var(--pp-space-2) var(--pp-space-4) var(--pp-space-6);\n  background: var(--pp-shell-bg-header);\n  border-bottom: 1px solid var(--pp-side-panel-divisor);\n  backdrop-filter: blur(var(--pp-blur));\n  -webkit-backdrop-filter: blur(var(--pp-blur));\n  min-height: 56px;\n  box-sizing: border-box;\n  flex-shrink: 0;\n}\n.panda-side-panel__title {\n  flex: 1;\n  font: var(--pp-font-header);\n  color: var(--pp-shell-text);\n  min-width: 0;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n.panda-side-panel__actions {\n  display: flex;\n  align-items: center;\n  gap: var(--pp-space-1);\n  flex-shrink: 0;\n}\n\n.panda-side-panel__body {\n  flex: 1;\n  min-height: 0;\n  padding: var(--pp-space-6);\n  overflow-y: auto;\n  overflow-x: hidden;\n  box-sizing: border-box;\n  scrollbar-width: thin;\n  scrollbar-color: var(--pp-foreground-40) transparent;\n}\n.panda-side-panel .panda-side-panel__body::-webkit-scrollbar {\n  width: 4px !important;\n  height: 4px !important;\n}\n.panda-side-panel .panda-side-panel__body::-webkit-scrollbar-track {\n  background: transparent !important;\n}\n.panda-side-panel .panda-side-panel__body::-webkit-scrollbar-thumb {\n  background: var(--pp-foreground-40) !important;\n  border-radius: 2px !important;\n}\n.panda-side-panel .panda-side-panel__body::-webkit-scrollbar-thumb:hover {\n  background: var(--pp-foreground-70) !important;\n}\n.panda-side-panel .panda-side-panel__body::-webkit-scrollbar-button {\n  display: none !important;\n  width: 0 !important;\n  height: 0 !important;\n}\n.panda-side-panel .panda-side-panel__body::-webkit-scrollbar-corner {\n  background: transparent !important;\n}\n\n.panda-side-panel__footer {\n  padding: var(--pp-space-4);\n  background: var(--pp-shell-bg-footer);\n  border-top: 1px solid var(--pp-side-panel-divisor);\n  flex-shrink: 0;\n}\n\n.panda-side-panel--fullscreen {\n  width: 100%;\n  border-left: 0;\n  border-radius: 0;\n}\n@media (max-width: 584px) {\n  .panda-side-panel {\n    border-left: 0;\n  }\n}\n.panda-side-panel--fullscreen .panda-side-panel__body {\n  padding: 0;\n}\nbody.panda-mobile-layout .panda-side-panel {\n  position: fixed;\n  top: 0;\n  right: 0;\n  bottom: 0;\n  left: 0;\n  width: 100vw;\n  height: 100vh;\n  border-left: 0;\n  border-radius: 0;\n  transform: translateY(100%);\n  opacity: 0;\n  transition:\n    transform 0.5s cubic-bezier(0.32, 0.72, 0, 1),\n    opacity 0.36s ease-in-out;\n}\nbody.panda-mobile-layout .panda-side-panel--open {\n  transform: translateY(0);\n  opacity: 1;\n  transition:\n    transform 0.32s cubic-bezier(0.32, 0.72, 0, 1),\n    opacity 0.22s ease-out;\n}\nbody.panda-mobile-layout .panda-side-panel--closing {\n  transform: translateY(100%);\n  opacity: 0;\n}\nbody.panda-mobile-layout .panda-side-panel__body {\n  padding: 12px;\n}\n\n.panda-textarea {\n 